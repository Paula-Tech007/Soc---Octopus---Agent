# SOC Investigation Copilot - LAB local isolado
# Copie este arquivo para .env.soc-copilot-lab antes de subir o Compose.
# Nao reutilize credenciais corporativas, bancos existentes ou Redis existente.

SOC_COPILOT_TZ=America/Sao_Paulo

# PostgreSQL LAB dedicado
SOC_COPILOT_POSTGRES_CONTAINER=soc-copilot-postgres-lab
SOC_COPILOT_POSTGRES_DB=soc_copilot_lab
SOC_COPILOT_POSTGRES_USER=soc_copilot_user
SOC_COPILOT_POSTGRES_PASSWORD=REPLACE_WITH_LOCAL_LAB_POSTGRES_PASSWORD
SOC_COPILOT_POSTGRES_BIND_ADDRESS=127.0.0.1
SOC_COPILOT_POSTGRES_PORT=5433

# Redis LAB dedicado
SOC_COPILOT_REDIS_CONTAINER=soc-copilot-redis-lab
SOC_COPILOT_REDIS_PASSWORD=REPLACE_WITH_LOCAL_LAB_REDIS_PASSWORD
SOC_COPILOT_REDIS_BIND_ADDRESS=127.0.0.1
SOC_COPILOT_REDIS_PORT=6380
